# IPFS Configuration
# Copy this file to .env and fill in your actual values

# Choose your IPFS provider: pinata, web3storage, infura, or local
REACT_APP_IPFS_PROVIDER=pinata

# Pinata Configuration (https://pinata.cloud)
REACT_APP_PINATA_API_KEY=your_pinata_api_key_here
REACT_APP_PINATA_API_SECRET=your_pinata_api_secret_here

# Web3.Storage Configuration (https://web3.storage)
REACT_APP_WEB3_STORAGE_TOKEN=your_web3_storage_token_here

# Infura IPFS Configuration (https://infura.io)
REACT_APP_INFURA_PROJECT_ID=your_infura_project_id_here
REACT_APP_INFURA_PROJECT_SECRET=your_infura_project_secret_here

# Local IPFS Node (if using local IPFS daemon)
REACT_APP_IPFS_LOCAL_ENDPOINT=http://localhost:5001
