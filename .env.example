# ============================================================
# DeChat Environment Variables — copy this to .env and fill in values
# ============================================================

# Smart Contract (deployed on Sepolia)
REACT_APP_CONTRACT_ADDRESS=your_deployed_contract_address_here

# IPFS Provider: pinata | web3storage | infura | local
REACT_APP_IPFS_PROVIDER=pinata

# Pinata (https://pinata.cloud)
REACT_APP_PINATA_API_KEY=your_pinata_api_key_here
REACT_APP_PINATA_API_SECRET=your_pinata_api_secret_here

# Web3.Storage (https://web3.storage)
REACT_APP_WEB3_STORAGE_TOKEN=your_web3_storage_token_here

# Infura IPFS (https://infura.io)
REACT_APP_INFURA_PROJECT_ID=your_infura_project_id_here
REACT_APP_INFURA_PROJECT_SECRET=your_infura_project_secret_here

# Local IPFS daemon endpoint
REACT_APP_IPFS_LOCAL_ENDPOINT=http://localhost:5001

# Server (used by server/server.js)
# Set this in production to your actual frontend URL
FRONTEND_URL=http://localhost:3000
PORT=3001
